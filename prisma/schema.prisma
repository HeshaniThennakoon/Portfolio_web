datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Settings {
  id             Int    @id @default(1)
  primaryColor   String @default("#2563EB")
  secondaryColor String @default("#06B6D4")
  accentColor    String @default("#8B5CF6")
  darkBg         String @default("#0F172A")
  lightBg        String @default("#F8FAFC")
  
  username       String @default("admin")
  passwordHash   String @db.VarChar(255)
  
  smtpHost       String @default("smtp.gmail.com")
  smtpPort       Int    @default(465)
  smtpUser       String @default("")
  smtpPass       String @default("")
  toEmail        String @default("thennakoonghm@gmail.com")
}

model HeroInfo {
  id          Int    @id @default(1)
  name        String @default("Heshani Thennakoon")
  headline    String @db.VarChar(500)
  subheadline String @db.VarChar(1000)
  roles       String @db.Text          // JSON array: ["Software Engineer", ...]
  stats       String @db.Text          // JSON array: [{"label": "Projects", "value": "10+"}]
  resumeUrl   String @default("/resume.pdf")
  profileImg  String @default("/profile.jpg")
}

model AboutInfo {
  id         Int    @id @default(1)
  story      String @db.Text
  highlights String @db.Text           // JSON array of strings
}

model SkillCategory {
  id       String @id @default(uuid())
  category String
  skills   String @db.Text             // JSON array of strings
  order    Int    @default(0)
}

model Experience {
  id               String @id @default(uuid())
  role             String
  company          String
  location         String
  period           String
  responsibilities String @db.Text     // JSON array of strings
  techStack        String @db.Text     // JSON array of strings
  order            Int    @default(0)
}

model Project {
  id           String  @id @default(uuid())
  title        String
  description  String  @db.Text
  technologies String  @db.Text        // JSON array of strings
  features     String  @db.Text        // JSON array of strings
  githubUrl    String  @default("")
  demoUrl      String  @default("")
  imageUrl     String  @default("")
  featured     Boolean @default(false)
  order        Int     @default(0)
}

model Education {
  id          String @id @default(uuid())
  degree      String
  institution String
  period      String
  focusAreas  String @db.Text          // JSON array of strings
  order       Int    @default(0)
}

model Achievements {
  id           Int    @id @default(1)
  leadership   String @db.Text         // JSON array of strings
  sports       String @db.Text         // JSON array of strings
  professional String @db.Text         // JSON array of strings
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
  replied   Boolean  @default(false)
}
